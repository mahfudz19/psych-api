# =============================================================================
# PSYCH-API ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your environment-specific values.
# NEVER commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# Application name and version
APP_NAME=psych-api
APP_VERSION=1.0.0-SNAPSHOT

# HTTP server configuration
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# Quarkus profile (dev, staging, prod)
QUARKUS_PROFILE=dev

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (MongoDB)
# -----------------------------------------------------------------------------
# MongoDB connection string
# Format: mongodb://[username:password@]host[:port]/database[?options]
MONGODB_URI=mongodb://localhost:27017/psych

# Database name
MONGODB_DATABASE=psych

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Enable/disable CORS
CORS_ENABLED=true

# Allowed origins (comma-separated)
# For development: http://localhost:5173,http://localhost:3000
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Allowed HTTP methods (comma-separated)
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed headers (comma-separated)
CORS_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin

# -----------------------------------------------------------------------------
# JWT SECURITY CONFIGURATION
# -----------------------------------------------------------------------------
# Token expiration time in seconds (default: 604800 = 7 days)
JWT_EXPIRES_IN=604800

# Token issuer (default: psych-api)
JWT_ISSUER=psych-api

# Path to RSA private key for signing tokens (RS256)
# The key file should be located in src/main/resources/keys/
JWT_SIGN_KEY_LOCATION=keys/privateKey.pem

# Verify token expiration (default: true)
JWT_VERIFY_EXPIRES_AT=true

# -----------------------------------------------------------------------------
# SUPERADMIN CONFIGURATION
# -----------------------------------------------------------------------------
# Comma-separated list of superadmin emails
# Superadmin memiliki akses penuh ke semua endpoint dan fitur sistem
# Format: email1@domain.com,email2@domain.com (tanpa spasi)
# Contoh: admin@psych.com,founder@psych.com,cto@psych.com
SUPERADMIN_EMAILS=admin@psychapi.com

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
# Log level (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Output console logs as JSON (useful for production log aggregation)
LOG_CONSOLE_JSON=false

# -----------------------------------------------------------------------------
# OPENAPI CONFIGURATION
# -----------------------------------------------------------------------------
# OpenAPI/Swagger documentation title
QUARKUS_SMALLRYE_OPENAPI_INFO_TITLE=Psych API

# OpenAPI/Swagger documentation version
QUARKUS_SMALLRYE_OPENAPI_INFO_VERSION=1.0.0-SNAPSHOT

# =============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# =============================================================================

# DEVELOPMENT ENVIRONMENT
# -----------------------
# QUARKUS_PROFILE=dev
# HTTP_PORT=8080
# MONGODB_URI=mongodb://localhost:27017/psych_dev
# LOG_LEVEL=DEBUG
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# STAGING ENVIRONMENT
# -------------------
# QUARKUS_PROFILE=staging
# HTTP_PORT=8080
# MONGODB_URI=mongodb://staging-db:27017/psych_staging
# LOG_LEVEL=INFO
# CORS_ORIGINS=https://staging.yourdomain.com

# PRODUCTION ENVIRONMENT
# ----------------------
# QUARKUS_PROFILE=prod
# HTTP_PORT=8080
# MONGODB_URI=mongodb://prod-db-cluster:27017/psych_prod
# LOG_LEVEL=WARN
# CORS_ORIGINS=https://yourdomain.com
# LOG_CONSOLE_JSON=true
